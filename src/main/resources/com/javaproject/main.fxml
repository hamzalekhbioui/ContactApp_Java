<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml" fx:controller="com.javaproject.Controller">
    <children>
        <!-- TableView Section -->
        <TableView fx:id="personTable" VBox.vgrow="ALWAYS" prefHeight="400.0" prefWidth="800.0">
            <columns>
                <TableColumn fx:id="firstNameColumn" text="First Name" />
                <TableColumn fx:id="lastNameColumn" text="Last Name" />
                <TableColumn fx:id="nicknameColumn" text="Nickname" />
                <TableColumn fx:id="phoneNumberColumn" text="Phone Number" />
                <TableColumn fx:id="addressColumn" text="Address" />
                <TableColumn fx:id="emailAddressColumn" text="Email Address" />
                <TableColumn fx:id="birthDateColumn" text="Birth Date" />
            </columns>
        </TableView>


        <!-- Form Section -->
        <GridPane hgap="10" vgap="10" alignment="CENTER">
            <!-- Labels -->
            <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
            <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
            <Label text="Nickname:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
            <Label text="Phone Number:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
            <Label text="Address:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
            <Label text="Email Address:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
            <Label text="Birth Date (YYYY-MM-DD):" GridPane.rowIndex="6" GridPane.columnIndex="0" />

            <!-- Text Fields -->
            <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="Enter First Name" />
            <TextField fx:id="lastNameField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Enter Last Name" />
            <TextField fx:id="nicknameField" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Enter Nickname" />
            <TextField fx:id="phoneNumberField" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="Enter Phone Number" />
            <TextField fx:id="addressField" GridPane.rowIndex="4" GridPane.columnIndex="1" promptText="Enter Address" />
            <TextField fx:id="emailAddressField" GridPane.rowIndex="5" GridPane.columnIndex="1" promptText="Enter Email Address" />
            <TextField fx:id="birthDateField" GridPane.rowIndex="6" GridPane.columnIndex="1" promptText="YYYY-MM-DD" />
        </GridPane>

        <!-- Buttons Section -->
        <HBox spacing="10" alignment="CENTER">
            <Button text="Save" onAction="#addPerson" styleClass="buttons" />
            <Button text="Delete" onAction="#deletePerson" styleClass="button_delete" />
            <Button text="Clear All" onAction="#clearFormFields" styleClass="buttons" />
        </HBox>
    </children>
</VBox>
