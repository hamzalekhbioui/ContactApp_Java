<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="com.javaproject.Controller">
    <!-- Header Section -->
    <children>
        <Label text="Manage Contacts" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-alignment: center;" alignment="CENTER" />

        <!-- Table Section -->
        <TableView fx:id="personTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="firstNameColumn" text="First Name" />
                <TableColumn fx:id="lastNameColumn" text="Last Name" />
                <TableColumn fx:id="nicknameColumn" text="Nickname" />
                <TableColumn fx:id="phoneNumberColumn" text="Phone Number" />
                <TableColumn fx:id="addressColumn" text="Address" />
                <TableColumn fx:id="emailAddressColumn" text="Email Address" />
                <TableColumn fx:id="birthDateColumn" text="Birth Date" />
            </columns>
        </TableView>

        <!-- Form Section -->
        <GridPane hgap="10" vgap="10" alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="100" />
                <ColumnConstraints halignment="LEFT" minWidth="200" />
            </columnConstraints>

            <children>
                <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="firstNameField" promptText="Enter First Name" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="lastNameField" promptText="Enter Last Name" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Nickname:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="nicknameField" promptText="Enter Nickname" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Phone Number:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="phoneNumberField" promptText="Enter Phone Number" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                <Label text="Address:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <TextField fx:id="addressField" promptText="Enter Address" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                <Label text="Email Address:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                <TextField fx:id="emailAddressField" promptText="Enter Email Address" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                <Label text="Birth Date (YYYY-MM-DD):" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                <TextField fx:id="birthDateField" promptText="YYYY-MM-DD" GridPane.rowIndex="6" GridPane.columnIndex="1" />
            </children>
        </GridPane>

        <!-- Buttons Section -->
        <HBox spacing="10" alignment="CENTER">
            <Button text="Save" onAction="#addPerson" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
            <Button text="Modify" onAction="#modifyPerson" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
            <Button text="Delete" onAction="#deletePerson" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
            <Button text="Clear All" onAction="#clearFormFields" />
        </HBox>
    </children>
</VBox>

